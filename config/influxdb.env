# config/influxdb.env
# ================================
# InfluxDB Configuration
# ================================

# Database name (harus sama dengan K6_OUT di docker-compose)
INFLUXDB_DB=k6

# HTTP Auth (set true jika production)
INFLUXDB_HTTP_AUTH_ENABLED=false

# Admin user (aktifkan jika AUTH_ENABLED=true)
# INFLUXDB_ADMIN_USER=admin
# INFLUXDB_ADMIN_PASSWORD=adminpassword

# User khusus untuk k6
# INFLUXDB_USER=k6user
# INFLUXDB_USER_PASSWORD=k6password

# Retention policy — berapa lama data disimpan
INFLUXDB_RETENTION=30d

# HTTP settings
INFLUXDB_HTTP_BIND_ADDRESS=:8086
INFLUXDB_REPORTING_DISABLED=true

# Logging
INFLUXDB_LOGGING_LEVEL=warn